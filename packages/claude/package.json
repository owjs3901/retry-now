{
  "name": "@retry-now/claude",
  "version": "0.2.3",
  "type": "module",
  "license": "MIT",
  "author": "owjs3901",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/owjs3901/retry-now.git",
    "directory": "packages/claude"
  },
  "publishConfig": {
    "access": "public"
  },
  "description": "retry-now integration for Claude Code — installs a /retry-now slash command that launches the reincarnation loop.",
  "bin": {
    "retry-now-claude": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/index.ts ./src/driver-entry.ts --outdir dist --target node --packages external"
  },
  "dependencies": {
    "@retry-now/core": "workspace:*"
  },
  "files": [
    "dist"
  ]
}

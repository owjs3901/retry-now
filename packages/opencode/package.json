{
  "name": "@retry-now/opencode",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "author": "owjs3901",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/owjs3901/retry-now.git",
    "directory": "packages/opencode"
  },
  "publishConfig": {
    "access": "public"
  },
  "description": "opencode plugin: registers /retry-now, which launches the retry-now reincarnation loop driver for the current project.",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/index.ts ./src/driver-entry.ts --outdir dist --target node --packages external"
  },
  "dependencies": {
    "@retry-now/core": "workspace:*"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.17.11"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "latest"
  },
  "files": [
    "dist",
    "src"
  ]
}

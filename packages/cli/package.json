{
  "name": "@retry-now/cli",
  "version": "0.2.7",
  "type": "module",
  "license": "MIT",
  "author": "owjs3901",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/owjs3901/retry-now.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "description": "retry-now CLI — `retry-now init` (interactive setup UI) + `run` (the reincarnation loop driver). Works with opencode, codex, or claude code.",
  "bin": {
    "retry-now": "./dist/index.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/index.ts --outdir dist --target node --packages external"
  },
  "dependencies": {
    "@retry-now/core": "workspace:*",
    "@retry-now/detect": "workspace:*",
    "@clack/prompts": "^1.7.0"
  },
  "files": [
    "dist"
  ]
}
